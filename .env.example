# mix-saving-bot configuration
# Copy this file to `.env` next to `pyproject.toml` and fill in values.

# ───────────────────────────────────────────────────────────
# Required for the live Telegram bot (get a token from @BotFather)
# ───────────────────────────────────────────────────────────
MIX_BOT_TOKEN=
# HTTP timeout (seconds) for uploading documents to Telegram; increase on slow uplinks (default 300).
# MIX_TELEGRAM_DOCUMENT_UPLOAD_TIMEOUT_SEC=300

# ───────────────────────────────────────────────────────────
# Logging & load shaping
# ───────────────────────────────────────────────────────────
MIX_LOG_LEVEL=INFO
# Verbose yt-dlp: every progress hook at INFO with full JSON (MIX_LOG_LEVEL=DEBUG includes hook payloads when this is false).
# MIX_DOWNLOAD_LOG_EVERY_PROGRESS=false

MIX_HIGH_WATER_QUEUE_DEPTH=200
MIX_RATE_LIMIT_MAX_EVENTS=35
MIX_RATE_LIMIT_WINDOW_SECONDS=60.0

# ───────────────────────────────────────────────────────────
# Job queue
# Use `memory` for a single-machine dev setup (default).
# Set `redis` for multi-process / multi-host workers.
# ───────────────────────────────────────────────────────────
MIX_QUEUE_BACKEND=memory
MIX_REDIS_URL=
MIX_REDIS_QUEUE_STREAM_KEY=mixdl:jobs
MIX_REDIS_QUEUE_GROUP=mixdl-workers
MIX_REDIS_QUEUE_CONSUMER_NAME=worker-1

# ───────────────────────────────────────────────────────────
# Download limits (sanitization + yt-dlp timeouts)
# ───────────────────────────────────────────────────────────
MIX_MAX_CONCURRENT_DOWNLOADS=2
MIX_DOWNLOAD_DEADLINE_SEC=600
MIX_MAX_OUTPUT_BYTES=2000000000
MIX_MAX_DURATION_SEC=7200
MIX_CACHE_ROOT_DIR=/tmp/mix-saving-cache
MIX_JOB_REPO_BACKEND=memory

# Reserved for future multi-backend cache implementations (currently unused).
MIX_CACHE_BACKEND=file

# Optional path to a custom yt-dlp config (see repository `services/yt-dlp.conf`)
MIX_YTDLP_CONFIG_PATH=

# Host allow-list (hostname only, lowercased internally):
#   • Comma-separated:  youtube.com,youtu.be,instagram.com
#   • JSON array:       ["youtube.com","tiktok.com"]
#   • Asterisk:        *  means "allow any host" (HIGH RISK — only for lab use)
# Leave unset for the built-in curated list in `core/settings.py`.
# If you explicitly set MIX_ALLOWED_HOSTS to empty string, defaults are used.
MIX_ALLOWED_HOSTS=

# ───────────────────────────────────────────────────────────
# Binary helpers (yt-dlp uses ffmpeg for merges / audio extraction)
# ───────────────────────────────────────────────────────────
MIX_SAVING_FFMPEG_LOCATION=
MIX_SAVING_YTDLP_COOKIESFILE=
MIX_SAVING_YTDLP_CONFIG=

# ───────────────────────────────────────────────────────────
# HTTP downloader bridge (optional module `services.remote_backend`)
# Not used by `run_bot.py` today, but available for custom deployments.
# ───────────────────────────────────────────────────────────
MIX_SAVING_API_BASE=
MIX_SAVING_BACKEND_URL=
MIX_BACKEND_JOBS_PATH=/api/v1/jobs
MIX_BACKEND_POLL_INTERVAL=1.25
MIX_BACKEND_JOB_TIMEOUT_SEC=900
